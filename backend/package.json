{
  "name": "inventario-kardex-backend",
  "version": "1.0.0",
  "description": "API GraphQL para sistema de inventario y kardex",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node-dev --transpile-only src/scripts/seed.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "graphql",
    "inventario",
    "kardex",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.9",
    "@graphql-tools/schema": "^10.0.33",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0",
    "graphql-tag": "^2.12.6",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
