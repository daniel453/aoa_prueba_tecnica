# =====================================================
# Backend env vars - copiar a .env y completar valores
# =====================================================

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database (MongoDB Atlas) ---
# Formato: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/inventario-kardex

# --- JWT ---
# Mínimo 16 caracteres. Genera uno fuerte: `openssl rand -hex 32`
JWT_SECRET=cambia-este-secreto-en-produccion-minimo-32-caracteres
JWT_EXPIRES_IN=8h

# --- CORS ---
# URL del frontend. Acepta una sola URL o varias separadas por coma.
# Los previews de Vercel (*.vercel.app) se permiten automáticamente.
# Ej. FRONTEND_URL=http://localhost:3000,https://inventario-kardex.vercel.app
FRONTEND_URL=http://localhost:3000
